{
  "name": "synthesis-treasury-ai",
  "version": "1.0.0",
  "description": "Autonomous corporate finance system - PerkOS TreasuryAI",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "deploy": "hardhat deploy --network base",
    "verify": "hardhat verify --network base",
    "compile": "hardhat compile",
    "treasury:start": "ts-node src/scripts/startTreasury.ts",
    "treasury:stop": "ts-node src/scripts/stopTreasury.ts",
    "metrics": "ts-node src/scripts/getTreasuryMetrics.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "defi",
    "treasury",
    "autonomous",
    "ethereum",
    "base",
    "yield-farming",
    "perkos"
  ],
  "author": "PerkOS Council",
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.9.0",
    "viem": "^2.1.0",
    "@chainlink/contracts": "^0.8.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@x402/fetch": "^1.0.0",
    "@x402/evm": "^1.0.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node-cron": "^3.0.11",
    "@types/jest": "^29.5.8",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "hardhat": "^2.19.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "hardhat-deploy": "^0.11.45",
    "hardhat-gas-reporter": "^1.0.9",
    "solidity-coverage": "^0.8.5",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "chai": "^4.3.10"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PerkOS-xyz/synthesis-treasury-ai.git"
  },
  "bugs": {
    "url": "https://github.com/PerkOS-xyz/synthesis-treasury-ai/issues"
  },
  "homepage": "https://github.com/PerkOS-xyz/synthesis-treasury-ai#readme"
}