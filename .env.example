# TreasuryAI Environment Configuration
# Copy to .env and fill in your values

# =============================================================
#                        NETWORK CONFIG
# =============================================================

# Primary network (Base for TreasuryAI)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Alternative networks
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

# =============================================================
#                        PRIVATE KEYS
# =============================================================

# WARNING: NEVER commit private keys to Git!
# Deployer wallet private key (for contract deployment)
PRIVATE_KEY=0x...

# Treasury agent private key (for autonomous operations)  
TREASURY_PRIVATE_KEY=0x...

# =============================================================
#                        CONTRACT ADDRESSES
# =============================================================

# TreasuryManager contract address (deployed)
TREASURY_CONTRACT=0x...

# Strategy contract addresses
LOCUS_USDC_STRATEGY=0x...
LIDO_STETH_STRATEGY=0x...
UNISWAP_V3_STRATEGY=0x...

# =============================================================
#                        API KEYS
# =============================================================

# Block explorers (for contract verification)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY
ARBISCAN_API_KEY=YOUR_ARBISCAN_API_KEY
OPTIMISM_ETHERSCAN_API_KEY=YOUR_OPTIMISM_ETHERSCAN_API_KEY

# Price feeds and data providers
CHAINLINK_API_KEY=YOUR_CHAINLINK_API_KEY
COINMARKETCAP_API_KEY=YOUR_CMC_API_KEY

# =============================================================
#                        TREASURY CONFIG
# =============================================================

# Server configuration
PORT=3001
NODE_ENV=development

# Auto-start treasury agent on startup
AUTO_START_TREASURY=false

# Risk management parameters
MAX_SLIPPAGE_BPS=300
MAX_SINGLE_TRADE_PERCENT=10
REBALANCE_THRESHOLD_BPS=200
MAX_DAILY_REBALANCES=3

# Performance targets (basis points)
TIER1_TARGET_APY=400
TIER2_TARGET_APY=800  
TIER3_TARGET_APY=1500

# =============================================================
#                        INTEGRATIONS
# =============================================================

# PerkOS x402 payment configuration
X402_ENDPOINT=https://api.x402.com
X402_API_KEY=YOUR_X402_API_KEY

# ERC-8004 identity registry
IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# =============================================================
#                        MONITORING
# =============================================================

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Performance monitoring
REPORT_GAS=true
ENABLE_METRICS=true
METRICS_INTERVAL=300000

# Emergency contacts (for notifications)
EMERGENCY_WEBHOOK_URL=https://hooks.slack.com/services/...
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# =============================================================
#                        SECURITY
# =============================================================

# Maximum emergency withdrawal percentage
EMERGENCY_WITHDRAW_LIMIT_PERCENT=10

# Multi-signature wallet for emergency functions
EMERGENCY_MULTISIG=0x...

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=100

# =============================================================
#                        DEVELOPMENT
# =============================================================

# Development settings
DEBUG=treasury:*
HARDHAT_NETWORK=localhost

# Testing configuration
TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
TEST_RPC_URL=http://127.0.0.1:8545